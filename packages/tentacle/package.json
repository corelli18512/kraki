{
  "name": "@kraki/tentacle",
  "version": "0.10.2",
  "description": "Kraki agent bridge \u2014 the arm that connects your coding agent to the head",
  "repository": {
    "type": "git",
    "url": "https://github.com/corelli18512/kraki",
    "directory": "packages/tentacle"
  },
  "homepage": "https://github.com/corelli18512/kraki/tree/main/packages/tentacle#readme",
  "bugs": {
    "url": "https://github.com/corelli18512/kraki/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "kraki": "dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "tsc --watch",
    "dev:local": "KRAKI_APP_URL=http://localhost:3000 node dist/cli.js",
    "build": "node ./scripts/build.mjs",
    "build:binary:local": "node ./scripts/build-local-binary.mjs",
    "clean": "node ./scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@inquirer/prompts": "^8.3.2",
    "@kraki/crypto": "workspace:*",
    "@kraki/protocol": "workspace:*",
    "chalk": "^5.6.2",
    "ora": "^9.3.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/pino": "^7.0.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.4",
    "postject": "1.0.0-alpha.6",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}