# Kraki Relay — Environment Configuration
# Copy to .env and fill in your values.

# Auth mode: open | github | apikey (default: open)
# AUTH_MODE=github

# GitHub OAuth App credentials (required for "Sign in with GitHub" on the web app)
# Create one at: GitHub → Settings → Developer settings → OAuth Apps → New
# Set the callback URL to your web app URL (e.g. http://localhost:3000)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# API key for apikey auth mode
# API_KEY=

# Server settings
# PORT=4000
# DB_PATH=kraki-head.db
# E2E_MODE=false
# PAIRING_ENABLED=true
# LOG_LEVEL=info
# LOG_PATH=
