{
  "name": "kraki-relay",
  "version": "0.1.0",
  "description": "Kraki relay server — the brain that routes messages between tentacles and apps",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "kraki-relay": "dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "tsx watch src/cli.ts",
    "build": "rm -rf dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kraki/protocol": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "undici": "^7.24.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
