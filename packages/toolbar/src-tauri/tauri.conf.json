{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kraki",
  "version": "0.0.0-dev",
  "identifier": "cloud.corelli.kraki.toolbar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm exec vite",
    "beforeBuildCommand": "pnpm build:icons && pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "qr",
        "title": "Pair device — Kraki",
        "width": 300,
        "height": 420,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": true,
        "center": true
      },
      {
        "label": "setup",
        "title": "Set up Kraki",
        "width": 480,
        "height": 580,
        "resizable": false,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["sidecar/kraki"],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
