# Kraki voice-broker — environment configuration
# Copy to .env and fill in your values. NEVER commit real secrets.

# ── Doubao / Volcengine streaming ASR credentials ──
# Get these at https://console.volcengine.com/speech (流式语音识别大模型)
DOUBAO_APP_KEY=your_app_id_here
DOUBAO_ACCESS_KEY=your_access_token_here

# Resource ID — picks model + billing mode
#   volc.bigasr.sauc.duration   = 1.0, billed by duration       (default)
#   volc.bigasr.sauc.concurrent = 1.0, billed by concurrency
#   volc.seedasr.sauc.duration  = 2.0 (seed), billed by duration
DOUBAO_RESOURCE_ID=volc.bigasr.sauc.duration

# Endpoint — async = result emitted only on change (recommended for dictation)
# DOUBAO_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# ── Local development knobs ──

# When set to 1, the broker/probe connect to the in-process mock Doubao server
# instead of the real one. Lets you test the whole stack without credentials.
# DOUBAO_MOCK=1

# Port the mock Doubao server listens on when DOUBAO_MOCK=1.
# MOCK_DOUBAO_PORT=7801

# ── Broker server ──
# Port the broker's WSS server listens on (arm clients connect here).
# BROKER_PORT=7800

# Log level: debug | info | warn | error
# LOG_LEVEL=info
